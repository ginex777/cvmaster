# --- Database ---
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://lba:change-me-strong-password@postgres:5432/lba

# --- Redis ---
REDIS_PASSWORD=change-me-strong-redis
REDIS_URL=redis://:change-me-strong-redis@redis:6379

# --- Auth / Security ---
# Production may use either Ed25519 keys or JWT_SECRET. Prefer Ed25519.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_SECRET=
IP_SALT=change-me-random-ip-hash-salt

# --- AI ---
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Email ---
MAIL_DOMAIN=example.de
RESEND_API_KEY=
RESEND_FROM="Lebenslauf-Agent <noreply@example.de>"

# --- Payments ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=
PADDLE_ENVIRONMENT=production
PADDLE_PRICE_PAY_PER_APP=pri_xxx
PADDLE_PRICE_PRO_MONTHLY=pri_xxx
PADDLE_PRICE_PRO_YEARLY=pri_xxx
PADDLE_CUSTOMER_PORTAL_URL=

# Frontend runtime config shape:
# window.__LBA_CONFIG__ = {
#   paddleClientToken: "client_xxx",
#   paddleEnvironment: "production",
#   paddlePriceIdPayPerApp: "pri_xxx",
#   paddlePriceIdProMonthly: "pri_xxx",
#   paddlePriceIdProYearly: "pri_xxx",
#   paddleCustomerPortalUrl: "https://customer-portal.paddle.com/..."
# }

# --- Sentry / Monitoring / Analytics ---
SENTRY_DSN=
PLAUSIBLE_DOMAIN=example.de
PLAUSIBLE_API_KEY=
BETTER_STACK_HEARTBEAT_URL=

# --- Crisp (loaded only after support-cookie consent) ---
CRISP_WEBSITE_ID=

# --- App ---
APP_URL=https://example.de
NODE_ENV=production

# --- Backups ---
BACKUP_RECIPIENT=backup@example.de
BACKUP_RETENTION_DAYS=30
BACKUP_BUCKET=
