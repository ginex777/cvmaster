# --- Datenbank ---
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://lba:change-me-strong-password@postgres:5432/lba

# --- Redis ---
REDIS_PASSWORD=change-me-strong-redis
REDIS_URL=redis://:change-me-strong-redis@redis:6379

# --- JWT (Ed25519, 64-Byte Hex) ---
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- AI ---
AI_PROVIDER=mistral
MISTRAL_API_KEY=
ALEPH_ALPHA_API_KEY=

# --- Email ---
RESEND_API_KEY=
RESEND_FROM=Lebenslauf-Agent <noreply@example.de>

# --- Payments ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_PAY_PER_APP=pri_xxx
PADDLE_PRICE_PRO_MONTHLY=pri_xxx
PADDLE_PRICE_PRO_YEARLY=pri_xxx

# --- Sentry / Monitoring ---
SENTRY_DSN=
PLAUSIBLE_DOMAIN=example.de

# --- Crisp (nach Cookie-Consent geladen) ---
CRISP_WEBSITE_ID=

# --- App ---
APP_URL=https://example.de
NODE_ENV=production
