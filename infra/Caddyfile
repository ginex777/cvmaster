:80 {
  encode zstd gzip

  # Sicherheits-Header (siehe SPEC § 23)
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Frame-Options "DENY"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.paddle.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data: https://*.paddle.com; connect-src 'self' https://*.paddle.com; frame-src https://*.paddle.com"
    -Server
  }

  handle /api/* {
    reverse_proxy api:3000
  }

  handle /health {
    rewrite * /api/health
    reverse_proxy api:3000
  }

  handle_path /.well-known/security.txt {
    respond `Contact: mailto:security@example.de
Expires: 2027-01-01T00:00:00.000Z
Preferred-Languages: de, en` 200
  }

  reverse_proxy frontend:80
}
